{
  "name": "arkive-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pkill -9 -f 'uvicorn.*8200' 2>/dev/null; pkill -9 -f 'node.*5173' 2>/dev/null; sleep 2; npx playwright test",
    "test:e2e:ui": "pkill -9 -f 'uvicorn.*8200' 2>/dev/null; pkill -9 -f 'node.*5173' 2>/dev/null; sleep 2; npx playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/typography": "^0.5.15",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^25.5.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.8",
    "svelte": "^5.53.11",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^5.4.11",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@fontsource/inter": "^5.1.1",
    "@fontsource/jetbrains-mono": "^5.1.2",
    "bits-ui": "^1.0.0-next.74",
    "chart.js": "^4.4.7",
    "clsx": "^2.1.1",
    "lucide-svelte": "^0.469.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "type": "module"
}
