<?xml version="1.0"?>
<Container version="2">
  <Name>Arkive</Name>
  <Repository>ghcr.io/islamdiaa/arkive:latest</Repository>
  <Registry>https://github.com/islamdiaa/arkive/pkgs/container/arkive</Registry>
  <Network>bridge</Network>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/islamdiaa/arkive/issues</Support>
  <Project>https://arkive.dev</Project>
  <Overview>
    Automated disaster recovery for Unraid servers. Arkive discovers your Docker containers, dumps databases (PostgreSQL, MariaDB, MongoDB, SQLite, Redis, InfluxDB), backs up flash config, and syncs everything to cloud storage via restic — all on autopilot.

    Features:
    - Zero-config container discovery with 50+ app profiles
    - Application-aware database dumps with integrity verification
    - Encrypted, deduplicated backups via restic
    - Multi-target cloud sync (B2, S3, SFTP, local)
    - One-click restore plan PDF
    - Discord/Slack/ntfy notifications
    - Beautiful dark-mode dashboard
  </Overview>
  <Category>Backup: Tools:</Category>
  <WebUI>http://[IP]:[PORT:8200]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/islamdiaa/arkive/main/unraid-template.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/islamdiaa/arkive/main/docs/icon.png</Icon>
  <ExtraParams>--restart unless-stopped --user 0:0</ExtraParams>
  <PostArgs/>
  <DonateText>Support Arkive development</DonateText>
  <DonateLink>https://arkive.dev</DonateLink>
  <Requires>Docker socket access and root runtime for full Unraid flash/SQLite coverage</Requires>
  <Config Name="Web UI Port" Target="8200" Default="8200" Mode="tcp" Description="Arkive web interface port" Type="Port" Display="always" Required="true" Mask="false"/>
  <Config Name="Config Directory" Target="/config" Default="/mnt/user/appdata/arkive" Mode="rw" Description="Arkive configuration and database" Type="Path" Display="always" Required="true" Mask="false"/>
  <Config Name="Docker Socket" Target="/var/run/docker.sock" Default="/var/run/docker.sock" Mode="ro" Description="Docker socket for container discovery" Type="Path" Display="always" Required="true" Mask="false"/>
  <Config Name="App Data" Target="/mnt/user/appdata" Default="/mnt/user/appdata" Mode="ro" Description="Unraid appdata directory (read-only)" Type="Path" Display="always" Required="false" Mask="false"/>
  <Config Name="Flash Drive" Target="/boot-config" Default="/boot/config" Mode="ro" Description="Unraid flash config directory for backup (mount /boot/config read-only)" Type="Path" Display="always" Required="false" Mask="false"/>
  <Config Name="Timezone" Target="TZ" Default="America/New_York" Mode="" Description="Container timezone" Type="Variable" Display="always" Required="false" Mask="false"/>
</Container>
